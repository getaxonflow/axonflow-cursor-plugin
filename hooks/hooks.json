{
  "description": "AxonFlow governance hooks — automatic policy enforcement, PII scanning, and audit trails for governed tool calls",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|NotebookEdit|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "${CURSOR_PLUGIN_ROOT}/scripts/pre-tool-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|NotebookEdit|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "${CURSOR_PLUGIN_ROOT}/scripts/post-tool-audit.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
