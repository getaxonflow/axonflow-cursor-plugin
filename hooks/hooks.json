{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "./scripts/pre-tool-check.sh",
        "matcher": "Shell|Write|Edit|Read|Task|NotebookEdit|mcp__.*",
        "timeout": 10
      }
    ],
    "postToolUse": [
      {
        "command": "./scripts/post-tool-audit.sh"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "./scripts/pre-tool-check.sh",
        "timeout": 10
      }
    ],
    "afterFileEdit": [
      {
        "command": "./scripts/post-tool-audit.sh"
      }
    ]
  }
}
