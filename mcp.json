{
  "mcpServers": {
    "axonflow": {
      "type": "http",
      "url": "${AXONFLOW_ENDPOINT:-http://localhost:8080}/api/v1/mcp-server",
      "headers": {
        "Authorization": "Basic ${AXONFLOW_AUTH}",
        "X-Axonflow-Client": "cursor-plugin/1.7.0",
        "X-License-Token": "${AXONFLOW_LICENSE_TOKEN}",
        "X-User-Token": "${AXONFLOW_USER_TOKEN}"
      }
    }
  }
}
